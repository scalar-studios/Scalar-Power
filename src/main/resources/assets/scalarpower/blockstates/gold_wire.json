{
  "multipart": [
    {   "apply": { "model": "scalarpower:block/gold_wire_center" }},
    {   "when": { "north": "true" },
      "apply": { "model": "scalarpower:block/gold_wire_side" }
    },
    {   "when": { "south": "true" },
      "apply": { "model": "scalarpower:block/gold_wire_side", "y": 180, "uvlock": true }
    },
    {   "when": { "east": "true" },
      "apply": { "model": "scalarpower:block/gold_wire_side", "y": 90, "uvlock": true }
    },
    {   "when": { "west": "true" },
      "apply": { "model": "scalarpower:block/gold_wire_side", "y": 270, "uvlock": true }
    },
    {   "when": { "up": "true" },
      "apply": { "model": "scalarpower:block/gold_wire_side", "x": 270, "uvlock": true }
    },
    {   "when": { "down": "true" },
      "apply": { "model": "scalarpower:block/gold_wire_side", "x": 90, "uvlock": true }
    }
  ]
}

